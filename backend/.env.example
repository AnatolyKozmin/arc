BOT_TOKEN=your_telegram_bot_token
SECRET_KEY=your-very-secret-key-change-this-in-production
# Локально: база в каталоге backend/ (или задай путь, например sqlite:///../data/arkadium.db — корневой data/ репо)
DATABASE_URL=sqlite:///./arkadium.db
# В Docker: compose подставит sqlite:////data/arkadium.db (том :/data) — не дублируй в .env, если не нужен override
# Comma-separated Telegram IDs for admins
ADMIN_TELEGRAM_IDS=123456789,987654321
# Comma-separated Telegram IDs for organizers
ORGANIZER_TELEGRAM_IDS=111111111
CORS_ORIGINS=http://localhost:5173,https://your-domain.com
