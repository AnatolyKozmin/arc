# ── Скопируй в .env и заполни ──────────────────────────────────────────────

# Домен сайта (без https://)
DOMAIN=example.ru

# Суффикс имён контейнеров (site1, site2, …) — см. docker-compose.yml в корне
SITE_SLUG=site1

# Email для Let's Encrypt уведомлений
ADMIN_EMAIL=admin@example.ru

# Токен бота от @BotFather
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Секретный ключ для JWT (любая длинная случайная строка)
SECRET_KEY=замени-на-случайную-строку-минимум-32-символа

# Telegram ID администраторов через запятую (без пробелов)
ADMIN_TELEGRAM_IDS=123456789,987654321

# Telegram ID организаторов (могут начислять коины) через запятую
ORGANIZER_TELEGRAM_IDS=

# CORS — разрешённые Origin для API (через запятую, без пробелов). Должен включать
# тот хост, с которого открыт сайт в браузере (putevod-ik.ru и/или www).
# В docker-compose по умолчанию: https://${DOMAIN} и https://www.${DOMAIN}
# CORS_ORIGINS=https://putevod-ik.ru,https://www.putevod-ik.ru

# Режим разработки: false — проверяет реальный initData от Telegram
DEV_MODE=false

# Логин/пароль для веб-админки (https://домен/#/admin/login) — смотри PANEL_* в контейнере:
#   docker compose exec backend printenv | grep PANEL
# Пароль с символами $ " # бери в одинарных кавычках в .env или экранируй.
PANEL_USERNAME=admin
PANEL_PASSWORD=arkadium2026
