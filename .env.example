# ── Скопируй в .env и заполни ──────────────────────────────────────────────

# Домен сайта (без https://) — сейчас: Arkadium на febnik.ru
DOMAIN=febnik.ru
#
# ── Мини-апп (только внутри Telegram) vs админка (браузер) ──
# Мини-апп: кнопка меню/inline, initData, WebApp. Админка: /admin/login в обычном браузере — отдельно.
# URL по умолчанию: https://${DOMAIN}/ — явно (рекомендуется):
# MINI_APP_URL=https://febnik.ru/
# После смены домена:
# 1) @BotFather → /mybots → твой бот → Bot Settings → Configure Mini App (или Menu Button) → тот же HTTPS URL.
# 2) На сервере: docker compose up -d --build --force-recreate bot frontend
# 3) Проверка: curl -sI https://febnik.ru/telegram-web-app.js  → 200 (скрипт с сайта, не с telegram.org)
# 4) BOT_TOKEN в .env = тот же, что в BotFather, иначе 401 на /api/auth/telegram
# Текст кнопки меню в чате:
# MENU_BUTTON_TEXT=🎮 Аркадиум

# Суффикс имён контейнеров (site1, site2, …) — см. docker-compose.yml в корне
SITE_SLUG=site1

# Каталог на хосте с arkadium.db — монтируется в контейнер как /data (файл /data/arkadium.db).
# Прод, база в named volume Docker:
# DATA_DIR=/var/lib/docker/volumes/arc_db-data/_data
DATA_DIR=./data
# Обычно не нужно: в compose уже DATABASE_URL=sqlite:////data/arkadium.db. Меняй только если путь к файлу другой.
# DATABASE_URL=sqlite:////data/arkadium.db

# Email для Let's Encrypt уведомлений
ADMIN_EMAIL=admin@example.ru

# Токен бота от @BotFather
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Секретный ключ для JWT (любая длинная случайная строка)
SECRET_KEY=замени-на-случайную-строку-минимум-32-символа

# Telegram ID администраторов через запятую (без пробелов)
ADMIN_TELEGRAM_IDS=123456789,987654321

# Telegram ID организаторов (могут начислять коины) через запятую
ORGANIZER_TELEGRAM_IDS=

# CORS — разрешённые Origin (через запятую). Должны совпадать с URL сайта (с www, если пользуешься).
# В docker-compose по умолчанию: https://${DOMAIN} и https://www.${DOMAIN}
# CORS_ORIGINS=https://example.ru,https://www.example.ru

# Режим разработки: false — проверяет реальный initData от Telegram
DEV_MODE=false

# В backend: печатать в лог каждый запрос method + path (только /api) — смотри, куда реально бьёт nginx
# LOG_API_REQUESTS=true

# Логин/пароль для веб-админки (https://домен/admin/login в браузере) — смотри PANEL_* в контейнере:
#   docker compose exec backend printenv | grep PANEL
# Пароль с символами $ " # бери в одинарных кавычках в .env или экранируй.
PANEL_USERNAME=admin
PANEL_PASSWORD=arkadium2026
